let
  var final : Integer
in
  begin
    final := 0;
    try
      try
        throw 10
      catch e1
	begin
	e1 := (e1 * 2);
        throw e1 ! Lanza 20 al nivel de afuera
	end
    catch e2
      final := e2;     ! Debe capturar el 20
      
    putint(final)      ! RESULTADO ESPERADO: 20
  end